<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Map</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
[data-theme="light"]{
  --bg:#f4f1ec;--surface:#fff;--surface2:#faf8f5;--border:#e4ddd4;
  --text:#18160f;--muted:#9e9890;--soft:#ede9e2;
  --shadow:0 2px 8px rgba(0,0,0,.07);--shadow-lg:0 6px 24px rgba(0,0,0,.13);
  --canvas-bg:#eee9e0;--grid:rgba(0,0,0,.06);
}
[data-theme="dark"]{
  --bg:#111010;--surface:#1c1b1a;--surface2:#232220;--border:#2e2c29;
  --text:#f0ece4;--muted:#6b6760;--soft:#252320;
  --shadow:0 2px 8px rgba(0,0,0,.3);--shadow-lg:0 6px 24px rgba(0,0,0,.45);
  --canvas-bg:#181716;--grid:rgba(255,255,255,.04);
}
body{background:var(--bg);color:var(--text);font-family:'Outfit',sans-serif;min-height:100vh;display:flex;flex-direction:column;height:100vh;overflow:hidden;}

/* ── Header ── */
.hdr{background:var(--surface);border-bottom:1px solid var(--border);padding:12px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0;box-shadow:var(--shadow);}
.hdr-title{font-size:1.2rem;font-weight:900;letter-spacing:-.03em;}
.hdr-sub{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--muted);letter-spacing:.05em;text-transform:uppercase;margin-top:2px;}
.hdr-right{margin-left:auto;display:flex;align-items:center;gap:8px;}
.hbtn{background:none;border:1px solid var(--border);color:var(--muted);font-family:'Outfit',sans-serif;font-size:.75rem;font-weight:600;padding:5px 13px;border-radius:7px;cursor:pointer;transition:all .15s;white-space:nowrap;}
.hbtn:hover{border-color:var(--text);color:var(--text);}
.hbtn.on{background:var(--text);color:var(--bg);border-color:var(--text);}

/* ── Tabs ── */
.tabs{background:var(--surface);border-bottom:1px solid var(--border);display:flex;padding:0 20px;flex-shrink:0;}
.tab{padding:9px 18px;font-size:.83rem;font-weight:600;cursor:pointer;border-bottom:2px solid transparent;color:var(--muted);transition:color .15s,border-color .15s;user-select:none;display:flex;align-items:center;gap:7px;}
.tab.active{color:var(--text);border-bottom-color:var(--text);}
.badge{background:var(--soft);border:1px solid var(--border);color:var(--muted);font-family:'DM Mono',monospace;font-size:.6rem;padding:1px 7px;border-radius:10px;transition:all .15s;}
.tab.active .badge{background:var(--text);color:var(--bg);border-color:var(--text);}

/* ── Main layout ── */
.main{display:flex;flex:1;overflow:hidden;}

/* ── Canvas ── */
.canvas-wrap{flex:1;overflow:auto;position:relative;background:var(--canvas-bg);}
.canvas{
  position:relative;
  width:1200px;height:700px;
  background-image:
    linear-gradient(var(--grid) 1px,transparent 1px),
    linear-gradient(90deg,var(--grid) 1px,transparent 1px);
  background-size:40px 40px;
  background-color:var(--canvas-bg);
}
.canvas.view-mode .room{cursor:default;}

/* ── Room boxes ── */
.room{
  position:absolute;
  background:var(--surface);
  border:1.5px solid var(--border);
  border-radius:10px;
  padding:7px 10px 8px;
  min-width:80px;
  cursor:grab;
  user-select:none;
  transition:box-shadow .15s,border-color .15s;
  box-shadow:var(--shadow);
}
.room:active{cursor:grabbing;box-shadow:var(--shadow-lg);}
.room.occupied{border-color:var(--text);}
.room.view-mode{cursor:default;}
.room-code{font-family:'DM Mono',monospace;font-size:.7rem;font-weight:600;color:var(--muted);margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;}
.room.occupied .room-code{color:var(--text);}
.room-del{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.7rem;padding:0 0 0 4px;line-height:1;opacity:0;transition:opacity .15s;}
.room:hover .room-del{opacity:1;}
.room-del:hover{color:#ef4444;}
.students{display:flex;flex-direction:column;gap:3px;}
.s-badge{font-size:.68rem;font-weight:700;padding:2px 7px;border-radius:5px;color:#fff;white-space:nowrap;line-height:1.5;}

/* ── Sidebar ── */
.sidebar{width:260px;flex-shrink:0;background:var(--surface);border-left:1px solid var(--border);overflow-y:auto;display:none;flex-direction:column;}
.sidebar.open{display:flex;}
.sb-section{padding:16px 18px;border-bottom:1px solid var(--border);}
.sb-title{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;font-weight:600;}
.sb-input{width:100%;background:var(--soft);border:1px solid var(--border);border-radius:7px;color:var(--text);font-family:'DM Mono',monospace;font-size:.78rem;padding:8px 11px;outline:none;margin-bottom:8px;transition:border-color .2s;}
.sb-input:focus{border-color:var(--text);}
.sb-btn{width:100%;background:var(--text);color:var(--bg);border:none;font-family:'Outfit',sans-serif;font-size:.8rem;font-weight:700;padding:8px;border-radius:8px;cursor:pointer;margin-bottom:6px;transition:opacity .15s;}
.sb-btn:hover{opacity:.82;}
.sb-btn.ghost{background:var(--soft);color:var(--text);border:1px solid var(--border);}
.room-chip{display:inline-flex;align-items:center;gap:5px;background:var(--soft);border:1px solid var(--border);border-radius:6px;padding:3px 8px;font-family:'DM Mono',monospace;font-size:.7rem;margin:3px;cursor:pointer;transition:border-color .15s;}
.room-chip:hover{border-color:var(--muted);}
.room-chip .x{color:var(--muted);font-size:.65rem;}
.room-chip:hover .x{color:#ef4444;}

/* ── Footer bar ── */
.footer{background:var(--surface);border-top:1px solid var(--border);padding:7px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0;flex-wrap:wrap;}
.footer-status{font-family:'DM Mono',monospace;font-size:.65rem;color:var(--muted);flex:1;}
.unplaced-label{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;flex-shrink:0;}
.unplaced-badges{display:flex;flex-wrap:wrap;gap:5px;}

/* ── Legend ── */
.legend{display:flex;align-items:center;gap:10px;flex-wrap:wrap;padding:6px 20px;background:var(--surface2);border-bottom:1px solid var(--border);flex-shrink:0;}
.leg-label{font-family:'DM Mono',monospace;font-size:.6rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;}
.leg-item{display:flex;align-items:center;gap:5px;font-size:.72rem;}
.leg-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}

/* ── Empty states ── */
.empty-canvas{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;pointer-events:none;}
.empty-canvas .icon{font-size:2.5rem;opacity:.25;}
.empty-canvas p{font-size:.85rem;color:var(--muted);text-align:center;line-height:1.7;max-width:320px;}

/* ── Modal ── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:500;display:flex;align-items:center;justify-content:center;}
.modal-bg.hidden{display:none;}
.modal{background:var(--surface);border-radius:16px;padding:28px;width:340px;max-width:92vw;box-shadow:var(--shadow-lg);}
.modal h2{font-size:1.1rem;font-weight:800;margin-bottom:14px;}
.modal input{width:100%;background:var(--soft);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Outfit',sans-serif;font-size:.9rem;padding:10px 14px;outline:none;margin-bottom:12px;}
.modal input:focus{border-color:var(--text);}
.modal-btns{display:flex;gap:8px;}
.modal-btns button{flex:1;border:none;font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:700;padding:10px;border-radius:9px;cursor:pointer;}
.modal-btns .ok{background:var(--text);color:var(--bg);}
.modal-btns .cancel{background:var(--soft);color:var(--text);border:1px solid var(--border);}
</style>
</head>
<body>

<!-- Server modal -->
<div class="modal-bg" id="serverModal">
  <div class="modal">
    <h2>🔌 Server URL</h2>
    <input id="serverInput" type="text" placeholder="https://timetable-server-r6nb.onrender.com" />
    <div class="modal-btns">
      <button class="ok" id="serverOk">Connect</button>
      <button class="cancel" id="serverSkip">Use default</button>
    </div>
  </div>
</div>

<div class="hdr">
  <div>
    <div class="hdr-title">📍 Student Map</div>
    <div class="hdr-sub" id="hdrSub">Connecting…</div>
  </div>
  <div class="hdr-right">
    <button class="hbtn" id="refreshBtn">↻ Refresh</button>
    <button class="hbtn" id="editBtn">✏ Edit Rooms</button>
    <button class="hbtn" id="themeBtn">◑</button>
  </div>
</div>

<div class="tabs">
  <div class="tab active" data-tab="now">Now <span class="badge" id="nowBadge">0</span></div>
  <div class="tab" data-tab="next">Next <span class="badge" id="nextBadge">0</span></div>
</div>

<div class="legend" id="legend" style="display:none;">
  <span class="leg-label">Key:</span>
  <div id="legendItems" style="display:flex;gap:12px;flex-wrap:wrap;"></div>
</div>

<div class="main">
  <div class="canvas-wrap" id="canvasWrap">
    <div class="canvas view-mode" id="canvas">
      <div class="empty-canvas" id="emptyMsg">
        <div class="icon">🏫</div>
        <p>No rooms placed yet.<br>Click <strong>✏ Edit Rooms</strong> to add rooms and drag them into position.</p>
      </div>
    </div>
  </div>

  <div class="sidebar" id="sidebar">
    <div class="sb-section">
      <div class="sb-title">Add Room</div>
      <input class="sb-input" id="newCode" placeholder="Room code, e.g. BR2" />
      <button class="sb-btn" id="addRoomBtn">+ Add Room</button>
      <button class="sb-btn ghost" id="autoBtn">🔍 Import from timetable</button>
    </div>
    <div class="sb-section" style="flex:1;">
      <div class="sb-title">Placed Rooms <span id="roomCount" style="font-weight:400;"></span></div>
      <div id="roomChips"></div>
    </div>
    <div class="sb-section">
      <button class="sb-btn ghost" id="clearAllBtn">🗑 Remove all rooms</button>
    </div>
  </div>
</div>

<div class="footer">
  <div class="footer-status" id="footerStatus">—</div>
  <div class="unplaced-label" id="unplacedLabel" style="display:none;">Not on map:</div>
  <div class="unplaced-badges" id="unplacedBadges"></div>
</div>

<script>
// ── Constants ───────────────────────────────────────────────────────────────
const DEFAULT_SERVER = 'https://timetable-server-r6nb.onrender.com';

const SCHEDULE = [
  { label:'Tutor Group', start:'08:50', end:'09:00' },
  { label:'Period 1',    start:'09:03', end:'09:53', period:1 },
  { label:'Period 2',    start:'09:56', end:'10:46', period:2 },
  { label:'Recess',      start:'10:46', end:'11:06', break:'Recess' },
  { label:'Period 3',    start:'11:10', end:'12:00', period:3 },
  { label:'Period 4',    start:'12:03', end:'12:53', period:4 },
  { label:'Lunch',       start:'12:53', end:'13:33', break:'Lunch' },
  { label:'Period 5',    start:'13:37', end:'14:27', period:5 },
  { label:'Period 6',    start:'14:30', end:'15:20', period:6 },
];

function toMins(t){const[h,m]=t.split(':').map(Number);return h*60+m;}
function nowMins(){const n=new Date();return n.getHours()*60+n.getMinutes()+n.getSeconds()/60;}

function getCurrentAndNext(){
  const nm=nowMins();
  let cur=null,nxt=null;
  for(const s of SCHEDULE){
    const a=toMins(s.start),b=toMins(s.end);
    if(nm>=a&&nm<b)cur=s;
    else if(nm<a&&!nxt)nxt=s;
  }
  return{cur,nxt};
}

// ── State ────────────────────────────────────────────────────────────────────
let server    = localStorage.getItem('tt-map-server') || DEFAULT_SERVER;
let timetable = null;
let names     = {};
let activeTab = 'now';
let editMode  = false;

// rooms: [{id, code, x, y}]
let rooms = loadRooms();
function loadRooms(){
  try{return JSON.parse(localStorage.getItem('tt-map-rooms')||'[]');}
  catch(e){return[];}
}
function persistRooms(){
  localStorage.setItem('tt-map-rooms',JSON.stringify(rooms));
}
function uid(){return Math.random().toString(36).slice(2,9);}

// ── Server modal ─────────────────────────────────────────────────────────────
const serverModal = document.getElementById('serverModal');
document.getElementById('serverInput').value = server;
function closeModal(){ serverModal.classList.add('hidden'); loadTimetable(); }
document.getElementById('serverOk').addEventListener('click',()=>{
  const v=document.getElementById('serverInput').value.trim().replace(/\/$/,'');
  if(v){server=v;localStorage.setItem('tt-map-server',v);}
  closeModal();
});
document.getElementById('serverSkip').addEventListener('click',closeModal);
if(localStorage.getItem('tt-map-server')){closeModal();}

// ── Theme ─────────────────────────────────────────────────────────────────────
const htmlEl=document.documentElement;
htmlEl.setAttribute('data-theme',localStorage.getItem('tt-theme')||'light');
document.getElementById('themeBtn').addEventListener('click',()=>{
  const n=htmlEl.getAttribute('data-theme')==='dark'?'light':'dark';
  htmlEl.setAttribute('data-theme',n);localStorage.setItem('tt-theme',n);
});

// ── Tabs ──────────────────────────────────────────────────────────────────────
document.querySelectorAll('.tab').forEach(t=>{
  t.addEventListener('click',()=>{
    document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
    t.classList.add('active');
    activeTab=t.dataset.tab;
    renderMap();
  });
});

// ── Edit mode ─────────────────────────────────────────────────────────────────
document.getElementById('editBtn').addEventListener('click',()=>{
  editMode=!editMode;
  document.getElementById('editBtn').classList.toggle('on',editMode);
  document.getElementById('sidebar').classList.toggle('open',editMode);
  document.getElementById('canvas').classList.toggle('view-mode',!editMode);
  // Toggle drag on room elements
  document.querySelectorAll('.room').forEach(el=>{
    el.classList.toggle('view-mode',!editMode);
  });
  renderSidebar();
});

// ── Load timetable ────────────────────────────────────────────────────────────
async function loadTimetable(){
  setStatus('Fetching…');
  try{
    const r=await fetch(server+'/timetable');
    if(!r.ok){setStatus('No timetable for today.');timetable={};names={};renderMap();return;}
    const d=await r.json();
    timetable=d.map||{};names=d.names||{};
    renderMap();
    setStatus('Updated '+new Date().toLocaleTimeString()+(d.sheet?' · '+d.sheet:''));
  }catch(e){
    // try localStorage cache from viewer
    try{
      const c=JSON.parse(localStorage.getItem('tt-cached-data')||'null');
      if(c&&c.map){timetable=c.map;names=c.names||{};renderMap();setStatus('⚠ Cached data — server unreachable');}
      else{setStatus('Cannot reach server: '+e.message);}
    }catch(_){setStatus('Error: '+e.message);}
  }
}

document.getElementById('refreshBtn').addEventListener('click',loadTimetable);
setInterval(loadTimetable,60000);

// ── Get student→room placements for a schedule slot ───────────────────────────
function getPlacements(slot){
  // returns Map<ROOMCODE, [{name,color,fg}]>
  const map=new Map();
  if(!timetable||!slot||!slot.period)return map;
  const p=slot.period;
  for(const[key,grp] of Object.entries(timetable)){
    const name=names[key]||key;
    const slots=grp.slots[p];
    if(!slots||!slots.length)continue;
    const room=(slots[0].d2||'').toUpperCase().trim();
    if(!room)continue;
    if(!map.has(room))map.set(room,[]);
    map.get(room).push({name,color:grp.bg,fg:grp.fg||null});
  }
  return map;
}

// ── Render map ────────────────────────────────────────────────────────────────
function renderMap(){
  if(!timetable){return;}
  const {cur,nxt}=getCurrentAndNext();
  const slot=activeTab==='now'?cur:nxt;
  const placements=getPlacements(slot);

  // Update badges
  const{cur:c,nxt:n}=getCurrentAndNext();
  let nc=0,nx=0;
  getPlacements(c).forEach(a=>nc+=a.length);
  getPlacements(n).forEach(a=>nx+=a.length);
  document.getElementById('nowBadge').textContent=nc;
  document.getElementById('nextBadge').textContent=nx;

  // Update header subtitle
  const dateStr=new Date().toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'short'});
  const periodStr=slot?slot.label:(activeTab==='now'?'After school':'No next period');
  document.getElementById('hdrSub').textContent=dateStr+' · '+periodStr;

  // Render legend
  renderLegend(placements);

  // Show/hide empty state
  const canvas=document.getElementById('canvas');
  document.getElementById('emptyMsg').style.display=rooms.length?'none':'';

  // Remove old room elements
  canvas.querySelectorAll('.room').forEach(el=>el.remove());

  // Render rooms
  const placedRooms=new Set(rooms.map(r=>r.code.toUpperCase()));
  rooms.forEach(room=>{
    const students=placements.get(room.code.toUpperCase())||[];
    const el=document.createElement('div');
    el.className='room'+(students.length?' occupied':'')+(editMode?'':' view-mode');
    el.style.left=room.x+'px';
    el.style.top=room.y+'px';
    el.dataset.id=room.id;

    const codeRow=document.createElement('div');
    codeRow.className='room-code';
    codeRow.appendChild(document.createTextNode(room.code));

    if(editMode){
      const del=document.createElement('button');
      del.className='room-del';
      del.textContent='✕';
      del.title='Remove room';
      del.addEventListener('click',e=>{e.stopPropagation();removeRoom(room.id);});
      codeRow.appendChild(del);
    }
    el.appendChild(codeRow);

    if(students.length){
      const stuDiv=document.createElement('div');
      stuDiv.className='students';
      students.forEach(s=>{
        const b=document.createElement('span');
        b.className='s-badge';
        b.style.background=s.color;
        if(s.fg)b.style.color=s.fg;
        b.textContent=s.name;
        stuDiv.appendChild(b);
      });
      el.appendChild(stuDiv);
    }

    if(editMode)makeDraggable(el,room);
    canvas.appendChild(el);
  });

  // Unplaced students
  const unplacedBadges=document.getElementById('unplacedBadges');
  const unplacedLabel=document.getElementById('unplacedLabel');
  unplacedBadges.innerHTML='';
  const unplaced=[];
  placements.forEach((students,code)=>{
    if(!placedRooms.has(code))students.forEach(s=>unplaced.push({...s,code}));
  });
  if(unplaced.length){
    unplacedLabel.style.display='';
    unplaced.forEach(s=>{
      const b=document.createElement('span');
      b.className='s-badge';
      b.style.background=s.color;
      if(s.fg)b.style.color=s.fg;
      b.textContent=s.name+' ('+s.code+')';
      b.title='Room '+s.code+' is not on the map — add it in Edit Rooms';
      unplacedBadges.appendChild(b);
    });
  }else{
    unplacedLabel.style.display='none';
  }
}

function renderLegend(placements){
  const legend=document.getElementById('legend');
  const items=document.getElementById('legendItems');
  const seen=new Map();
  placements.forEach(students=>students.forEach(s=>{if(!seen.has(s.name))seen.set(s.name,s);}));
  if(!seen.size){legend.style.display='none';return;}
  legend.style.display='flex';
  items.innerHTML='';
  seen.forEach((s,name)=>{
    const item=document.createElement('div');
    item.className='leg-item';
    const dot=document.createElement('div');
    dot.className='leg-dot';
    dot.style.background=s.color;
    item.appendChild(dot);
    item.appendChild(document.createTextNode(name));
    items.appendChild(item);
  });
}

// ── Drag rooms ────────────────────────────────────────────────────────────────
function makeDraggable(el,room){
  let sx,sy,ox,oy;
  el.addEventListener('mousedown',e=>{
    if(e.target.classList.contains('room-del'))return;
    e.preventDefault();
    sx=e.clientX;sy=e.clientY;ox=room.x;oy=room.y;
    el.style.zIndex=10;
    function move(e2){
      room.x=Math.max(0,ox+e2.clientX-sx);
      room.y=Math.max(0,oy+e2.clientY-sy);
      el.style.left=room.x+'px';
      el.style.top=room.y+'px';
    }
    function up(){
      el.style.zIndex='';
      persistRooms();
      renderSidebar();
      document.removeEventListener('mousemove',move);
      document.removeEventListener('mouseup',up);
    }
    document.addEventListener('mousemove',move);
    document.addEventListener('mouseup',up);
  });

  // Touch support
  el.addEventListener('touchstart',e=>{
    if(e.target.classList.contains('room-del'))return;
    const t=e.touches[0];
    sx=t.clientX;sy=t.clientY;ox=room.x;oy=room.y;
    el.style.zIndex=10;
    function tmove(e2){
      const t2=e2.touches[0];
      room.x=Math.max(0,ox+t2.clientX-sx);
      room.y=Math.max(0,oy+t2.clientY-sy);
      el.style.left=room.x+'px';
      el.style.top=room.y+'px';
    }
    function tup(){
      el.style.zIndex='';
      persistRooms();
      document.removeEventListener('touchmove',tmove);
      document.removeEventListener('touchend',tup);
    }
    document.addEventListener('touchmove',tmove,{passive:true});
    document.addEventListener('touchend',tup);
  },{passive:true});
}

// ── Sidebar ───────────────────────────────────────────────────────────────────
function renderSidebar(){
  const chips=document.getElementById('roomChips');
  chips.innerHTML='';
  document.getElementById('roomCount').textContent='('+rooms.length+')';
  [...rooms].sort((a,b)=>a.code.localeCompare(b.code)).forEach(room=>{
    const chip=document.createElement('span');
    chip.className='room-chip';
    chip.innerHTML=room.code+'<span class="x">✕</span>';
    chip.querySelector('.x').addEventListener('click',e=>{e.stopPropagation();removeRoom(room.id);});
    chip.addEventListener('click',()=>{
      // Scroll canvas to room
      const el=document.querySelector('.room[data-id="'+room.id+'"]');
      if(el)el.scrollIntoView({behavior:'smooth',block:'center',inline:'center'});
    });
    chips.appendChild(chip);
  });
}

// ── Add / remove rooms ────────────────────────────────────────────────────────
document.getElementById('addRoomBtn').addEventListener('click',addRoomFromInput);
document.getElementById('newCode').addEventListener('keydown',e=>{if(e.key==='Enter')addRoomFromInput();});

function addRoomFromInput(){
  const code=document.getElementById('newCode').value.trim().toUpperCase();
  if(!code)return;
  if(rooms.find(r=>r.code===code)){alert('Room '+code+' already exists.');return;}
  addRoom(code);
  document.getElementById('newCode').value='';
}

function addRoom(code){
  // Place new rooms in a loose grid so they don't overlap
  const idx=rooms.length;
  const cols=8;
  const x=20+(idx%cols)*140;
  const y=20+Math.floor(idx/cols)*100;
  rooms.push({id:uid(),code,x,y});
  persistRooms();
  renderSidebar();
  renderMap();
}

function removeRoom(id){
  rooms=rooms.filter(r=>r.id!==id);
  persistRooms();
  renderSidebar();
  renderMap();
}

// Auto-import from timetable
document.getElementById('autoBtn').addEventListener('click',()=>{
  if(!timetable||!Object.keys(timetable).length){alert('Load the timetable first — click ↻ Refresh.');return;}
  const found=new Set();
  for(const grp of Object.values(timetable)){
    for(const slots of Object.values(grp.slots)){
      for(const slot of slots){
        if(slot.d2)found.add(slot.d2.toUpperCase().trim());
      }
    }
  }
  if(!found.size){alert('No room codes found in timetable data.');return;}
  const existing=new Set(rooms.map(r=>r.code));
  const toAdd=[...found].filter(r=>!existing.has(r)).sort();
  if(!toAdd.length){alert('All rooms from the timetable are already on the map.');return;}
  toAdd.forEach(code=>addRoom(code));
  alert('Added '+toAdd.length+' rooms: '+toAdd.join(', ')+'\n\nDrag them into position on the map.');
});

// Clear all
document.getElementById('clearAllBtn').addEventListener('click',()=>{
  if(!confirm('Remove all rooms from the map?'))return;
  rooms=[];persistRooms();renderSidebar();renderMap();
});

function setStatus(t){document.getElementById('footerStatus').textContent=t;}

// ── Init ──────────────────────────────────────────────────────────────────────
renderSidebar();
renderMap();
</script>
</body>
</html>
